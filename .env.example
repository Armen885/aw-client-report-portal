# Optional configuration. Copy to .env and fill in as needed.
PORT=3000

# Persistence:
# - Leave TURSO_* unset for local dev -> uses a local SQLite file (file:./data/portal.db).
# - Set both for production (e.g. Vercel) -> uses Turso (libSQL) cloud database.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Self-hosting on a box with a persistent disk (e.g. Railway volume):
# RAILWAY_DATABASE_PATH=/data/portal.db

# Enables the Canva export flow (otherwise it degrades to "download & import")
# CANVA_API_KEY=
